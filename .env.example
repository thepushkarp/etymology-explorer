# Etymology Explorer Environment Variables

# ===========================================
# OpenAI API Key (required)
# ===========================================
# Server-side key for OpenAI Responses API access
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ===========================================
# Admin Secret (required for /api/admin/stats)
# ===========================================
# Any random string — used to authenticate admin stats endpoint
ADMIN_SECRET=

# ===========================================
# Upstash KV (optional - for caching + rate limiting)
# ===========================================
# Create a free Redis database at https://upstash.com
# Enables: result caching, rate limiting, and monthly budget enforcement
ETYMOLOGY_KV_REST_API_URL=
ETYMOLOGY_KV_REST_API_TOKEN=

# ===========================================
# ElevenLabs TTS (optional - for pronunciation audio)
# ===========================================
# Get API key at https://elevenlabs.io
# Set ELEVENLABS_VOICE_ID to a voice available in your My Voices list.
# Free-tier accounts cannot use Voice Library/community voices via the API.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ===========================================
# Feature Flags (optional — all default to enabled/false)
# ===========================================
# PUBLIC_SEARCH_ENABLED=true
# PRONUNCIATION_ENABLED=true
# FORCE_CACHE_ONLY=false
